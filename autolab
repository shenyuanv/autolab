#!/usr/bin/env bash
set -euo pipefail

# Autolab — Automated Research Harness CLI
# Single bash script, no build step, zero LLM in orchestrator

AUTOLAB_VERSION="0.1.0"
AUTOLAB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ============================================================================
# Utilities
# ============================================================================

die() {
    echo "ERROR: $*" >&2
    exit 1
}

info() {
    echo "INFO: $*" >&2
}

# Check required dependencies
check_deps() {
    local missing=()
    for cmd in git jq python3; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing required commands: ${missing[*]}"
    fi
    # Check Python yaml module
    if ! python3 -c "import yaml" 2>/dev/null; then
        die "Python yaml module not available (pip install pyyaml)"
    fi
}

# ============================================================================
# YAML Parsing (via Python)
# ============================================================================

# Parse YAML config and return as JSON
parse_config_to_json() {
    local config_file="$1"

    if [[ ! -f "$config_file" ]]; then
        echo "FAIL: autolab.yaml not found at $config_file" >&2
        return 1
    fi

    python3 -c "
import sys, json, yaml
try:
    with open('$config_file', 'r') as f:
        config = yaml.safe_load(f)
    if config is None:
        config = {}
    print(json.dumps(config))
except yaml.YAMLError as e:
    print(f'FAIL: Invalid YAML syntax: {e}', file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f'FAIL: Error parsing YAML: {e}', file=sys.stderr)
    sys.exit(1)
"
}

# Validate required fields and structure
validate_config() {
    local config_file="$1"

    echo "Validating $config_file..." >&2

    local config
    if ! config=$(parse_config_to_json "$config_file"); then
        return 1
    fi

    local errors=0

    has_field() {
        local field="$1"
        echo "$config" | jq "has(\"$field\")" 2>/dev/null | grep -q "true"
    }

    # Required string fields
    for field in project artifacts evaluate; do
        if ! has_field "$field"; then
            echo "FAIL: Required field '$field' not found in autolab.yaml" >&2
            ((errors++))
        fi
    done

    # Required object: metric
    if ! has_field "metric"; then
        echo "FAIL: Required field 'metric' not found in autolab.yaml" >&2
        ((errors++))
    else
        if ! echo "$config" | jq '.metric.name' 2>/dev/null | grep -qv "null"; then
            echo "FAIL: metric.name is required" >&2
            ((errors++))
        fi
        local direction
        direction=$(echo "$config" | jq -r '.metric.direction // "maximize"' 2>/dev/null)
        if [[ "$direction" != "maximize" && "$direction" != "minimize" ]]; then
            echo "FAIL: metric.direction must be 'maximize' or 'minimize', got '$direction'" >&2
            ((errors++))
        fi
    fi

    # Artifacts must be non-empty list
    if has_field "artifacts"; then
        local artifacts_type
        artifacts_type=$(echo "$config" | jq -r '.artifacts | type' 2>/dev/null)
        if [[ "$artifacts_type" != "array" ]]; then
            echo "FAIL: artifacts must be a list" >&2
            ((errors++))
        else
            local num_artifacts
            num_artifacts=$(echo "$config" | jq '.artifacts | length' 2>/dev/null)
            if [[ $num_artifacts -eq 0 ]]; then
                echo "FAIL: artifacts list must not be empty" >&2
                ((errors++))
            fi
        fi
    fi

    # Evaluate not empty
    if has_field "evaluate"; then
        local eval_value
        eval_value=$(echo "$config" | jq -r '.evaluate' 2>/dev/null)
        if [[ -z "$eval_value" ]]; then
            echo "FAIL: evaluate command cannot be empty" >&2
            ((errors++))
        fi
    fi

    # Optional: agent must be object
    if has_field "agent"; then
        if [[ "$(echo "$config" | jq -r '.agent | type' 2>/dev/null)" != "object" ]]; then
            echo "FAIL: agent must be an object" >&2
            ((errors++))
        fi
    fi

    # Optional: stages must be array with ids
    if has_field "stages"; then
        if [[ "$(echo "$config" | jq -r '.stages | type' 2>/dev/null)" != "array" ]]; then
            echo "FAIL: stages must be a list" >&2
            ((errors++))
        else
            local num_stages
            num_stages=$(echo "$config" | jq '.stages | length' 2>/dev/null)
            for ((i = 0; i < num_stages; i++)); do
                local stage_id
                stage_id=$(echo "$config" | jq -r ".stages[$i].id // \"\"" 2>/dev/null)
                if [[ -z "$stage_id" ]]; then
                    echo "FAIL: Stage $i missing required 'id' field" >&2
                    ((errors++))
                fi
            done
        fi
    fi

    # Optional: stop/notify must be objects
    for field in stop notify; do
        if has_field "$field"; then
            if [[ "$(echo "$config" | jq -r ".$field | type" 2>/dev/null)" != "object" ]]; then
                echo "FAIL: $field must be an object" >&2
                ((errors++))
            fi
        fi
    done

    [[ $errors -eq 0 ]]
}

# ============================================================================
# Commands
# ============================================================================

# autolab init: Initialize a new project
cmd_init() {
    local project_dir="${1:-.}"

    # Create project directory if needed
    if [[ ! -d "$project_dir" ]]; then
        mkdir -p "$project_dir"
    fi

    cd "$project_dir"

    # Check if autolab.yaml already exists (don't overwrite)
    if [[ -f autolab.yaml ]]; then
        info "autolab.yaml already exists, skipping"
    else
        # Create autolab.yaml template
        cat > autolab.yaml << 'YAML'
# Autolab Configuration
project: my-research
description: "A research project"

# What the agent modifies
artifacts:
  - artifact.py

# How to evaluate (must output JSON to stdout)
evaluate: "bash evaluate.sh"

# Primary metric to optimize
metric:
  name: f1
  direction: maximize  # or minimize

# Agent configuration
agent:
  command: claude
  flags: "--dangerously-skip-permissions --max-turns 30"

# Roadmap
stages:
  - id: baseline
    goal: "Establish baseline"
    metric: f1
    threshold: 0.60

# Stop conditions
stop:
  max_rounds: 50
  plateau: 5
  time_limit: "1h"

# Notifications
notify:
  slack_channel: null
  on: []
YAML
        info "Created autolab.yaml"
    fi

    # Create program.md template
    if [[ -f program.md ]]; then
        info "program.md already exists, skipping"
    else
        cat > program.md << 'MD'
# Research Instructions

## Objective
Describe the research goal and what success looks like.

## Current State
The agent will see the current artifact and recent experiment history.

## Task
Make one focused improvement to the artifact(s).

## Evaluation
The evaluation script will automatically measure performance.

## Tips
- One change per round
- Document your reasoning
- Each round is independent
MD
        info "Created program.md"
    fi

    # Create evaluate.sh template
    if [[ -f evaluate.sh ]]; then
        info "evaluate.sh already exists, skipping"
    else
        cat > evaluate.sh << 'EVAL'
#!/usr/bin/env bash
set -euo pipefail

# Evaluation script
# Must output valid JSON to stdout
# Exit 0 on success, non-zero on failure

# Example: run some test and compute metrics
# PRECISION=$(python3 -c "print(0.91)")
# RECALL=$(python3 -c "print(0.84)")
# F1=$(python3 -c "print(0.87)")

# For now, output dummy metrics for testing
cat << 'JSON'
{
  "f1": 0.75,
  "precision": 0.80,
  "recall": 0.71
}
JSON
EVAL
        chmod +x evaluate.sh
        info "Created evaluate.sh (executable)"
    fi

    # Create directory structure
    local dirs=(
        "artifacts"
        "data"
        "checkpoints/best"
        "checkpoints/history"
        "results/rounds"
    )

    for dir in "${dirs[@]}"; do
        if [[ ! -d "$dir" ]]; then
            mkdir -p "$dir"
            info "Created directory: $dir"
        fi
    done

    # Create .gitignore if it doesn't exist
    if [[ -f .gitignore ]]; then
        info ".gitignore already exists, skipping"
    else
        cat > .gitignore << 'GITIGNORE'
# Autolab directories
results/
checkpoints/
*.log
__pycache__/
*.pyc
.env
GITIGNORE
        info "Created .gitignore"
    fi

    # Initialize git repo if needed
    if [[ ! -d .git ]]; then
        git init > /dev/null
        git config user.email "autolab@local" 2>/dev/null || true
        git config user.name "Autolab" 2>/dev/null || true
        info "Initialized git repository"
    fi

    # Add initial commit if there are no commits yet
    if ! git rev-parse HEAD &>/dev/null; then
        # Stage all files
        git add autolab.yaml program.md evaluate.sh .gitignore
        git commit -m "Initial autolab project setup" > /dev/null || true
        info "Created initial git commit"
    fi

    echo "Autolab project initialized in $(pwd)"
}

# autolab validate: Validate project config
cmd_validate() {
    local config_file="${1:-.}/autolab.yaml"

    if validate_config "$config_file"; then
        echo "✓ autolab.yaml is valid" >&2
        return 0
    else
        return 1
    fi
}

# ============================================================================
# Checkpoint Management
# ============================================================================

# promote: Create checkpoint on improvement
# Usage: promote <round> <metric_value> <metric_name>
promote() {
    local round="$1"
    local metric_value="$2"
    local metric_name="$3"

    if [[ ! -d checkpoints/best ]]; then
        mkdir -p checkpoints/best
    fi

    if [[ ! -d checkpoints/history ]]; then
        mkdir -p checkpoints/history
    fi

    # Format round number with zero padding (e.g., round-001)
    local round_dir="checkpoints/history/round-$(printf '%03d' "$round")"
    mkdir -p "$round_dir"

    # Parse config to get artifacts list
    local config
    if ! config=$(parse_config_to_json "autolab.yaml"); then
        die "Failed to parse autolab.yaml"
    fi

    # Copy each artifact to both best/ and history/round-NNN/
    local num_artifacts
    num_artifacts=$(echo "$config" | jq '.artifacts | length' 2>/dev/null)
    for ((i = 0; i < num_artifacts; i++)); do
        local artifact
        artifact=$(echo "$config" | jq -r ".artifacts[$i]" 2>/dev/null)
        if [[ -n "$artifact" && -f "$artifact" ]]; then
            cp "$artifact" "checkpoints/best/$artifact"
            cp "$artifact" "$round_dir/$artifact"
        fi
    done

    # Create git commit with round and metrics in message
    local commit_msg="Checkpoint: Round $round — $metric_name: $metric_value"
    git add checkpoints/best > /dev/null 2>&1 || true
    git add checkpoints/history > /dev/null 2>&1 || true
    git commit -m "$commit_msg" > /dev/null 2>&1 || true

    info "Promoted checkpoint for round $round ($metric_name: $metric_value)"
}

# discard: Revert artifacts to last best checkpoint on regression
discard() {
    if [[ ! -d checkpoints/best ]]; then
        # No best checkpoint yet, nothing to discard
        return 0
    fi

    # Parse config to get artifacts list
    local config
    if ! config=$(parse_config_to_json "autolab.yaml"); then
        die "Failed to parse autolab.yaml"
    fi

    # Restore each artifact from best/
    local num_artifacts
    num_artifacts=$(echo "$config" | jq '.artifacts | length' 2>/dev/null)
    for ((i = 0; i < num_artifacts; i++)); do
        local artifact
        artifact=$(echo "$config" | jq -r ".artifacts[$i]" 2>/dev/null)
        if [[ -n "$artifact" && -f "checkpoints/best/$artifact" ]]; then
            cp "checkpoints/best/$artifact" "$artifact"
        fi
    done

    info "Discarded artifacts and reverted to best checkpoint"
}

# ============================================================================
# Spawn: Launch sub-agent for a research round
# ============================================================================

# Generate prompt for sub-agent
# Usage: generate_prompt <round> <config_json>
generate_prompt() {
    local round="$1"
    local config="$2"

    # Extract config fields
    local project metric_name metric_dir stage_id stage_goal max_rounds
    project=$(echo "$config" | jq -r '.project // "unknown"' 2>/dev/null)
    metric_name=$(echo "$config" | jq -r '.metric.name // "f1"' 2>/dev/null)
    metric_dir=$(echo "$config" | jq -r '.metric.direction // "maximize"' 2>/dev/null)
    max_rounds=$(echo "$config" | jq -r '.stop.max_rounds // 50' 2>/dev/null)

    # Get stage info if available
    if echo "$config" | jq '.stages' 2>/dev/null | grep -q "^\["; then
        local num_stages
        num_stages=$(echo "$config" | jq '.stages | length' 2>/dev/null)
        if [[ $num_stages -gt 0 ]]; then
            # Get first stage (baseline)
            stage_id=$(echo "$config" | jq -r '.stages[0].id // ""' 2>/dev/null)
            stage_goal=$(echo "$config" | jq -r '.stages[0].goal // ""' 2>/dev/null)
        fi
    fi

    # Default values
    stage_id="${stage_id:-baseline}"
    stage_goal="${stage_goal:-Improve the artifact}"

    # Get artifacts list
    local artifacts_str=""
    if echo "$config" | jq '.artifacts' 2>/dev/null | grep -q "^\["; then
        local num_artifacts
        num_artifacts=$(echo "$config" | jq '.artifacts | length' 2>/dev/null)
        for ((i = 0; i < num_artifacts; i++)); do
            local artifact
            artifact=$(echo "$config" | jq -r ".artifacts[$i]" 2>/dev/null)
            if [[ -n "$artifact" ]]; then
                if [[ -z "$artifacts_str" ]]; then
                    artifacts_str="$artifact"
                else
                    artifacts_str="$artifacts_str, $artifact"
                fi
            fi
        done
    fi
    artifacts_str="${artifacts_str:-artifact.py}"

    # Get evaluate command
    local eval_cmd
    eval_cmd=$(echo "$config" | jq -r '.evaluate // ""' 2>/dev/null)

    # Get threshold if available
    local threshold=""
    if echo "$config" | jq '.stages' 2>/dev/null | grep -q "^\["; then
        threshold=$(echo "$config" | jq -r '.stages[0].threshold // ""' 2>/dev/null)
    fi

    # Generate the prompt
    cat << PROMPT
# Research Round $round

## Your Task
Read program.md for the full research context. You are in stage: $stage_id.
Goal: $stage_goal
Target: $metric_name $metric_dir ${threshold:-(no threshold set)} (current best: N/A for round 1)

## Current State
- Round: $round of max $max_rounds
- Stage: $stage_id (1/1)
- Best $metric_name: N/A (not yet evaluated)
- Rounds since improvement: 0

## Instructions
1. Read program.md for detailed research instructions
2. Examine the current artifact(s): $artifacts_str
3. Make ONE focused improvement
4. Run the evaluation: $eval_cmd
5. Report the results

Do NOT try multiple changes in one round. One change, one eval.
PROMPT
}

# Spawn sub-agent for a research round
# Usage: spawn_agent <round> <config_dir>
spawn_agent() {
    local round="$1"
    local config_dir="${2:-.}"

    local config_file="$config_dir/autolab.yaml"

    # Validate config
    if [[ ! -f "$config_file" ]]; then
        die "autolab.yaml not found at $config_file"
    fi

    if ! validate_config "$config_file" > /dev/null 2>&1; then
        die "Invalid autolab.yaml: config validation failed"
    fi

    # Parse config
    local config
    if ! config=$(parse_config_to_json "$config_file"); then
        die "Failed to parse autolab.yaml"
    fi

    # Create round directory
    local round_num
    round_num=$(printf '%03d' "$round")
    local round_dir="$config_dir/results/rounds/round-$round_num"
    mkdir -p "$round_dir"

    # Create results directory if needed
    mkdir -p "$config_dir/results"

    # Generate prompt
    local prompt
    prompt=$(generate_prompt "$round" "$config")

    # Get agent command and flags from config
    local agent_cmd agent_flags
    agent_cmd=$(echo "$config" | jq -r '.agent.command // "claude"' 2>/dev/null)
    agent_flags=$(echo "$config" | jq -r '.agent.flags // ""' 2>/dev/null)

    # Save prompt to round directory
    echo "$prompt" > "$round_dir/prompt.txt"

    # Spawn agent in background with prompt
    # The agent receives the prompt as context and logs output to the round directory
    cd "$config_dir"

    # Launch agent with prompt, capture PID, and save log
    {
        echo "$prompt"
        echo ""
        echo "---AGENT-START---"
    } | $agent_cmd $agent_flags > "$round_dir/agent.log" 2>&1 &

    local agent_pid=$!

    # Save PID to round directory
    echo "$agent_pid" > "$round_dir/agent.pid"

    info "Spawned agent for round $round (PID: $agent_pid, log: $round_dir/agent.log)"
}

# ============================================================================
# Eval Command: Run evaluate script and parse metrics
# ============================================================================

# Parse metric from evaluate JSON output
# Usage: parse_metric_from_json <json_string> <metric_name>
parse_metric_from_json() {
    local json_str="$1"
    local metric_name="$2"

    # Extract the metric value from JSON
    echo "$json_str" | jq -r ".\"$metric_name\" // empty" 2>/dev/null
}

# Compare two metric values based on direction
# Usage: compare_metrics <current> <best> <direction>
# Returns: 0 if improved, 1 if regressed or same
compare_metrics() {
    local current="$1"
    local best="$2"
    local direction="$3"

    # Handle non-numeric values
    if ! { echo "$current" | grep -E '^-?[0-9]+(\.[0-9]+)?$' > /dev/null && \
           echo "$best" | grep -E '^-?[0-9]+(\.[0-9]+)?$' > /dev/null; }; then
        die "Invalid numeric metric values: current=$current best=$best"
    fi

    if [[ "$direction" == "maximize" ]]; then
        # Improved if current > best
        (( $(echo "$current > $best" | bc -l) )) && return 0 || return 1
    else
        # Minimized if current < best
        (( $(echo "$current < $best" | bc -l) )) && return 0 || return 1
    fi
}

# autolab promote: Create checkpoint on improvement
cmd_promote() {
    local round="${1:-}"
    local metric_value="${2:-}"
    local metric_name="${3:-}"

    if [[ -z "$round" || -z "$metric_value" || -z "$metric_name" ]]; then
        die "Usage: autolab promote <round> <metric_value> <metric_name>"
    fi

    promote "$round" "$metric_value" "$metric_name"
}

# autolab discard: Revert artifacts to last best checkpoint
cmd_discard() {
    discard
}

# autolab restore: Restore artifacts from a specific checkpoint
cmd_restore() {
    local round="${1:-}"

    if [[ -z "$round" ]]; then
        die "Usage: autolab restore <round>"
    fi

    # Format round number with zero padding
    local round_dir="checkpoints/history/round-$(printf '%03d' "$round")"

    if [[ ! -d "$round_dir" ]]; then
        die "Checkpoint for round $round not found at $round_dir"
    fi

    # Parse config to get artifacts list
    local config
    if ! config=$(parse_config_to_json "autolab.yaml"); then
        die "Failed to parse autolab.yaml"
    fi

    # Restore each artifact from the checkpoint
    local num_artifacts
    num_artifacts=$(echo "$config" | jq '.artifacts | length' 2>/dev/null)
    for ((i = 0; i < num_artifacts; i++)); do
        local artifact
        artifact=$(echo "$config" | jq -r ".artifacts[$i]" 2>/dev/null)
        if [[ -n "$artifact" && -f "$round_dir/$artifact" ]]; then
            cp "$round_dir/$artifact" "$artifact"
        fi
    done

    info "Restored artifacts from round $round"
}

# autolab eval: Run evaluation script and parse results
cmd_eval() {
    local config_dir="${1:-.}"
    local config_file="$config_dir/autolab.yaml"

    # Validate config exists and is valid
    if [[ ! -f "$config_file" ]]; then
        die "autolab.yaml not found at $config_file"
    fi

    if ! validate_config "$config_file" > /dev/null 2>&1; then
        die "Invalid autolab.yaml: config validation failed"
    fi

    # Parse config
    local config
    if ! config=$(parse_config_to_json "$config_file"); then
        die "Failed to parse autolab.yaml"
    fi

    # Extract evaluate command
    local eval_cmd
    eval_cmd=$(echo "$config" | jq -r '.evaluate' 2>/dev/null)
    if [[ -z "$eval_cmd" || "$eval_cmd" == "null" ]]; then
        die "No evaluate command configured"
    fi

    # Extract metric info
    local metric_name metric_direction
    metric_name=$(echo "$config" | jq -r '.metric.name' 2>/dev/null)
    metric_direction=$(echo "$config" | jq -r '.metric.direction // "maximize"' 2>/dev/null)

    if [[ -z "$metric_name" || "$metric_name" == "null" ]]; then
        die "No metric name configured"
    fi

    # Change to config directory to run evaluate command
    cd "$config_dir"

    # Run evaluate command
    local eval_output
    if ! eval_output=$(eval "$eval_cmd" 2>&1); then
        die "Evaluate command failed: $eval_cmd"
    fi

    # Validate JSON
    if ! echo "$eval_output" | jq empty 2>/dev/null; then
        die "Evaluate script did not return valid JSON: $eval_output"
    fi

    # Parse metric from output
    local metric_value
    metric_value=$(parse_metric_from_json "$eval_output" "$metric_name")

    if [[ -z "$metric_value" ]]; then
        die "Metric '$metric_name' not found in evaluate output"
    fi

    # Output result as JSON
    cat << EOF
{
  "metric": "$metric_name",
  "value": $metric_value,
  "direction": "$metric_direction"
}
EOF
}

# autolab spawn: Spawn sub-agent for a research round
cmd_spawn() {
    local round="${1:-1}"
    local config_dir="${2:-.}"

    spawn_agent "$round" "$config_dir"
}

# ============================================================================
# Status and History Commands
# ============================================================================

# autolab status: Show current state
cmd_status() {
    local config_dir="${1:-.}"
    local config_file="$config_dir/autolab.yaml"
    local exp_file="$config_dir/results/experiments.jsonl"

    # Validate config exists
    if [[ ! -f "$config_file" ]]; then
        die "autolab.yaml not found at $config_file"
    fi

    # Parse config
    local config
    if ! config=$(parse_config_to_json "$config_file"); then
        die "Failed to parse autolab.yaml"
    fi

    # Extract metric info
    local metric_name
    metric_name=$(echo "$config" | jq -r '.metric.name' 2>/dev/null)

    # Load best metrics if available
    local best_json
    best_json=$(load_best_metrics)

    echo "=== Autolab Status ==="
    echo ""

    # Check if experiments have been run
    if [[ ! -f "$exp_file" ]]; then
        echo "Status: No experiments run yet"
        echo "Total rounds: 0"
        return 0
    fi

    # Count total rounds
    local total_rounds
    total_rounds=$(wc -l < "$exp_file" 2>/dev/null | tr -d ' ' || echo "0")

    # Get best metric info
    local best_metric best_round
    if echo "$best_json" | jq -e '.value' > /dev/null 2>&1; then
        best_metric=$(echo "$best_json" | jq -r '.value' 2>/dev/null)
        best_round=$(echo "$best_json" | jq -r '.round // "unknown"' 2>/dev/null)
        echo "Status: Completed"
        echo "Best metric ($metric_name): $best_metric (round $best_round)"
    else
        echo "Status: Completed"
        echo "Best metric ($metric_name): None yet"
    fi

    echo "Total rounds: $total_rounds"

    # Count plateau
    local plateau_count
    plateau_count=$(count_plateau_rounds)
    echo "Rounds since improvement: $plateau_count"

    # Show last round metrics if available
    if [[ -f "$exp_file" && $total_rounds -gt 0 ]]; then
        local last_entry
        last_entry=$(tail -1 "$exp_file")
        local last_metric last_improved last_timestamp
        last_metric=$(echo "$last_entry" | jq -r '.metric_value // "unknown"' 2>/dev/null)
        last_improved=$(echo "$last_entry" | jq -r '.improved // false' 2>/dev/null)
        last_timestamp=$(echo "$last_entry" | jq -r '.timestamp // "unknown"' 2>/dev/null)
        echo ""
        echo "Last round: Round $total_rounds"
        echo "  Metric: $last_metric"
        echo "  Improved: $last_improved"
        echo "  Time: $last_timestamp"
    fi
}

# autolab history: List all experiments
cmd_history() {
    local config_dir="${1:-.}"
    local exp_file="$config_dir/results/experiments.jsonl"

    # Check if experiments file exists
    if [[ ! -f "$exp_file" ]]; then
        echo "No experiments recorded yet"
        return 0
    fi

    # Check if file is empty
    if [[ ! -s "$exp_file" ]]; then
        echo "No experiments recorded yet"
        return 0
    fi

    # Print header
    printf "%-8s %-15s %-12s %-30s\n" "Round" "Metric" "Improved" "Timestamp"
    printf "%-8s %-15s %-12s %-30s\n" "-----" "------" "---------" "---------"

    # Process each line and format as table
    while IFS= read -r line; do
        # Skip empty lines
        [[ -z "$line" ]] && continue

        local round metric improved timestamp
        round=$(echo "$line" | jq -r '.round // "-"' 2>/dev/null)
        metric=$(echo "$line" | jq -r '.metric_value // "-"' 2>/dev/null)
        improved=$(echo "$line" | jq -r '.improved // false' 2>/dev/null)
        timestamp=$(echo "$line" | jq -r '.timestamp // "-"' 2>/dev/null)

        # Format improved as checkmark or dash
        if [[ "$improved" == "true" ]]; then
            improved="✓"
        else
            improved="-"
        fi

        printf "%-8s %-15s %-12s %-30s\n" "$round" "$metric" "$improved" "$timestamp"
    done < "$exp_file"
}

# ============================================================================
# Core Loop: Start command implementation
# ============================================================================

# Load best metrics from checkpoint history
# Returns JSON with metric info or "{}" if no best exists
load_best_metrics() {
    local best_file="checkpoints/best/.best_metrics.json"

    if [[ -f "$best_file" ]]; then
        cat "$best_file"
    else
        echo "{}"
    fi
}

# Load best metric value
# Usage: get_best_metric_value <metric_name>
get_best_metric_value() {
    local metric_name="$1"
    local best_json
    best_json=$(load_best_metrics)

    if echo "$best_json" | jq -e ".value" > /dev/null 2>&1; then
        echo "$best_json" | jq -r '.value' 2>/dev/null
    else
        echo ""
    fi
}

# Check if agent process is still running
# Usage: is_agent_running <round_dir>
is_agent_running() {
    local round_dir="$1"
    local pid_file="$round_dir/agent.pid"

    if [[ ! -f "$pid_file" ]]; then
        return 1
    fi

    local pid
    pid=$(cat "$pid_file" 2>/dev/null) || return 1

    if [[ -z "$pid" ]]; then
        return 1
    fi

    # Check if process exists
    if kill -0 "$pid" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

# Wait for agent to finish running
# Usage: wait_for_agent <round_dir> [timeout_seconds]
wait_for_agent() {
    local round_dir="$1"
    local timeout="${2:-600}"  # default 10 minutes
    local elapsed=0

    while [[ $elapsed -lt $timeout ]]; do
        if ! is_agent_running "$round_dir"; then
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    die "Agent timeout after ${timeout}s for round $(basename $round_dir)"
}

# Run evaluation and save metrics
# Usage: run_and_save_eval <round_dir> <config_dir>
run_and_save_eval() {
    local round_dir="$1"
    local config_dir="$2"

    # Run eval command and save output
    local eval_output
    if eval_output=$("$0" eval "$config_dir" 2>&1); then
        # Save eval output
        echo "$eval_output" > "$round_dir/eval-output.json"
        echo "$eval_output"
    else
        die "Evaluation failed for $(basename $round_dir)"
    fi
}

# Append entry to experiments.jsonl
# Usage: append_experiment_entry <config_dir> <round> <metrics_json>
append_experiment_entry() {
    local config_dir="$1"
    local round="$2"
    local metrics_json="$3"
    local improved="${4:-false}"
    local stage="${5:-baseline}"

    local exp_file="$config_dir/results/experiments.jsonl"
    mkdir -p "$(dirname "$exp_file")"

    # Extract metric value from JSON
    local metric_value
    metric_value=$(echo "$metrics_json" | jq -r '.value // "null"' 2>/dev/null)

    # Create experiment entry as single-line JSON (compact output)
    local entry
    entry=$(jq -cn \
        --arg round "$round" \
        --arg metric_value "$metric_value" \
        --arg improved "$improved" \
        --arg stage "$stage" \
        --arg timestamp "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '{round: ($round|tonumber), metric_value: ($metric_value|tonumber), improved: ($improved|test("true")), stage: $stage, timestamp: $timestamp}')

    echo "$entry" >> "$exp_file"
}

# Load last recorded best metric from experiments.jsonl
# Returns the metric value or empty string if none
get_last_best_metric() {
    local exp_file="results/experiments.jsonl"

    if [[ ! -f "$exp_file" ]]; then
        echo ""
        return
    fi

    # Find last entry with improved=true
    local last_best
    last_best=$(grep '"improved": true' "$exp_file" | tail -1 | jq -r '.metric_value // ""' 2>/dev/null)

    if [[ -z "$last_best" ]]; then
        # If no improvement yet, get first entry's value
        last_best=$(tail -1 "$exp_file" | jq -r '.metric_value // ""' 2>/dev/null)
    fi

    echo "$last_best"
}

# Count consecutive rounds without improvement
# Returns the count
count_plateau_rounds() {
    local exp_file="results/experiments.jsonl"

    if [[ ! -f "$exp_file" ]]; then
        echo "0"
        return
    fi

    # Count from the end backwards until we find a line with improved=true
    local count=0

    # Process file in reverse
    while IFS= read -r line; do
        # Skip empty lines
        [[ -z "$line" ]] && continue

        # Check if this line has improved=true
        if echo "$line" | jq -e '.improved == true' > /dev/null 2>&1; then
            # Found an improvement, return the count
            echo "$count"
            return
        fi

        # Count this line as no improvement
        ((count++))
    done < <(tac "$exp_file")

    # If we get here, no improvements found at all
    echo "$count"
}

# Determine if we should stop the loop
# Usage: should_stop <config_json> <current_round>
should_stop() {
    local config="$1"
    local current_round="$2"

    # Check max_rounds
    local max_rounds
    max_rounds=$(echo "$config" | jq -r '.stop.max_rounds // 100' 2>/dev/null)

    if [[ $current_round -ge $max_rounds ]]; then
        info "Reached max rounds ($current_round >= $max_rounds)"
        return 0
    fi

    # Check plateau
    local plateau_threshold
    plateau_threshold=$(echo "$config" | jq -r '.stop.plateau // 10' 2>/dev/null)

    local plateau_count
    plateau_count=$(count_plateau_rounds)

    if [[ $plateau_count -ge $plateau_threshold ]]; then
        info "Plateau detected: $plateau_count rounds without improvement"
        return 0
    fi

    return 1
}

# autolab start: Main research loop
cmd_start() {
    local config_dir="${1:-.}"
    local config_file="$config_dir/autolab.yaml"

    # Validate config
    if [[ ! -f "$config_file" ]]; then
        die "autolab.yaml not found at $config_file"
    fi

    if ! validate_config "$config_file" > /dev/null 2>&1; then
        die "Invalid autolab.yaml: config validation failed"
    fi

    # Parse config
    local config
    if ! config=$(parse_config_to_json "$config_file"); then
        die "Failed to parse autolab.yaml"
    fi

    # Extract config values
    local max_rounds
    max_rounds=$(echo "$config" | jq -r '.stop.max_rounds // 100' 2>/dev/null)
    local metric_name
    metric_name=$(echo "$config" | jq -r '.metric.name' 2>/dev/null)
    local metric_direction
    metric_direction=$(echo "$config" | jq -r '.metric.direction // "maximize"' 2>/dev/null)

    info "Starting research loop: max_rounds=$max_rounds, metric=$metric_name"

    # Initialize state
    local current_round=1
    local best_metric=""

    # Main loop
    while true; do
        local round_num
        round_num=$(printf '%03d' "$current_round")
        local round_dir="$config_dir/results/rounds/round-$round_num"

        info "=== Round $current_round ==="

        # Spawn agent
        spawn_agent "$current_round" "$config_dir"

        # Wait for agent to complete
        wait_for_agent "$round_dir" 300

        # Run evaluation
        info "Running evaluation for round $current_round..."
        local eval_output
        eval_output=$(run_and_save_eval "$round_dir" "$config_dir")

        # Parse metrics
        local metric_value
        metric_value=$(echo "$eval_output" | jq -r '.value // empty' 2>/dev/null)

        if [[ -z "$metric_value" ]]; then
            die "Failed to extract metric value from evaluation"
        fi

        info "Round $current_round: $metric_name = $metric_value"

        # Determine if improved
        local improved=false
        if [[ -z "$best_metric" ]]; then
            # First round - always improve
            improved=true
            best_metric="$metric_value"
        else
            # Compare metrics
            if compare_metrics "$metric_value" "$best_metric" "$metric_direction"; then
                improved=true
                best_metric="$metric_value"
            fi
        fi

        # Promote or discard
        if [[ "$improved" == "true" ]]; then
            promote "$current_round" "$metric_value" "$metric_name"

            # Save best metrics
            mkdir -p "$config_dir/checkpoints/best"
            cat > "$config_dir/checkpoints/best/.best_metrics.json" << EOF
{
  "metric": "$metric_name",
  "value": $metric_value,
  "direction": "$metric_direction",
  "round": $current_round
}
EOF
        else
            discard
            info "Discarded round $current_round (regression or no improvement)"
        fi

        # Log experiment entry
        append_experiment_entry "$config_dir" "$current_round" "$eval_output" "$improved" "baseline"

        # Check stop conditions
        if should_stop "$config" "$current_round"; then
            info "Research loop stopped after $current_round rounds"
            break
        fi

        # Increment round
        ((current_round++))

        # Small delay before next round
        sleep 1
    done

    info "Research complete"
    echo "Final best metric: $metric_name = $best_metric"
}

# Show help
cmd_help() {
    cat << 'HELP'
autolab — Automated Research Harness

USAGE:
  autolab <command> [args]

COMMANDS:
  init [DIR]                      Initialize a new project structure
  validate [DIR]                  Validate autolab.yaml
  status [DIR]                    Show current state and best metrics
  history [DIR]                   List all experiments
  start [DIR]                     Run main research loop (foreground)
  spawn <round> [DIR]             Spawn sub-agent for a research round
  eval [DIR]                      Run evaluate script and parse metrics
  promote <round> <value> <name>  Create checkpoint on improvement
  discard                         Revert artifacts to last best checkpoint
  restore <round>                 Restore artifacts from specific checkpoint
  help                            Show this help message
  version                         Show version

For more information, see DESIGN.md and CLAUDE.md
HELP
}

# Show version
cmd_version() {
    echo "autolab version $AUTOLAB_VERSION"
}

# ============================================================================
# Main
# ============================================================================

main() {
    check_deps

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        init)      cmd_init "$@" ;;
        validate)  cmd_validate "$@" ;;
        status)    cmd_status "$@" ;;
        history)   cmd_history "$@" ;;
        start)     cmd_start "$@" ;;
        spawn)     cmd_spawn "$@" ;;
        eval)      cmd_eval "$@" ;;
        promote)   cmd_promote "$@" ;;
        discard)   cmd_discard "$@" ;;
        restore)   cmd_restore "$@" ;;
        help)      cmd_help ;;
        version)   cmd_version ;;
        *)         die "Unknown command: $cmd (use 'autolab help')" ;;
    esac
}

main "$@"
