#!/usr/bin/env bash
set -euo pipefail

# Autolab — Automated Research Harness CLI
# Single bash script, no build step, zero LLM in orchestrator

AUTOLAB_VERSION="0.1.0"
AUTOLAB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ============================================================================
# Utilities
# ============================================================================

die() {
    echo "ERROR: $*" >&2
    exit 1
}

info() {
    echo "INFO: $*" >&2
}

# Check required dependencies
check_deps() {
    local missing=()
    for cmd in git jq python3; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing required commands: ${missing[*]}"
    fi
    # Check Python yaml module
    if ! python3 -c "import yaml" 2>/dev/null; then
        die "Python yaml module not available (pip install pyyaml)"
    fi
}

# ============================================================================
# YAML Parsing (via Python)
# ============================================================================

# Parse YAML config and return as JSON
parse_config_to_json() {
    local config_file="$1"

    if [[ ! -f "$config_file" ]]; then
        echo "FAIL: autolab.yaml not found at $config_file" >&2
        return 1
    fi

    python3 -c "
import sys, json, yaml
try:
    with open('$config_file', 'r') as f:
        config = yaml.safe_load(f)
    if config is None:
        config = {}
    print(json.dumps(config))
except yaml.YAMLError as e:
    print(f'FAIL: Invalid YAML syntax: {e}', file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f'FAIL: Error parsing YAML: {e}', file=sys.stderr)
    sys.exit(1)
"
}

# Validate required fields and structure
validate_config() {
    local config_file="$1"

    echo "Validating $config_file..." >&2

    local config
    if ! config=$(parse_config_to_json "$config_file"); then
        return 1
    fi

    local errors=0

    has_field() {
        local field="$1"
        echo "$config" | jq "has(\"$field\")" 2>/dev/null | grep -q "true"
    }

    # Required string fields
    for field in project artifacts evaluate; do
        if ! has_field "$field"; then
            echo "FAIL: Required field '$field' not found in autolab.yaml" >&2
            ((errors++))
        fi
    done

    # Required object: metric
    if ! has_field "metric"; then
        echo "FAIL: Required field 'metric' not found in autolab.yaml" >&2
        ((errors++))
    else
        if ! echo "$config" | jq '.metric.name' 2>/dev/null | grep -qv "null"; then
            echo "FAIL: metric.name is required" >&2
            ((errors++))
        fi
        local direction
        direction=$(echo "$config" | jq -r '.metric.direction // "maximize"' 2>/dev/null)
        if [[ "$direction" != "maximize" && "$direction" != "minimize" ]]; then
            echo "FAIL: metric.direction must be 'maximize' or 'minimize', got '$direction'" >&2
            ((errors++))
        fi
    fi

    # Artifacts must be non-empty list
    if has_field "artifacts"; then
        local artifacts_type
        artifacts_type=$(echo "$config" | jq -r '.artifacts | type' 2>/dev/null)
        if [[ "$artifacts_type" != "array" ]]; then
            echo "FAIL: artifacts must be a list" >&2
            ((errors++))
        else
            local num_artifacts
            num_artifacts=$(echo "$config" | jq '.artifacts | length' 2>/dev/null)
            if [[ $num_artifacts -eq 0 ]]; then
                echo "FAIL: artifacts list must not be empty" >&2
                ((errors++))
            fi
        fi
    fi

    # Evaluate not empty
    if has_field "evaluate"; then
        local eval_value
        eval_value=$(echo "$config" | jq -r '.evaluate' 2>/dev/null)
        if [[ -z "$eval_value" ]]; then
            echo "FAIL: evaluate command cannot be empty" >&2
            ((errors++))
        fi
    fi

    # Optional: agent must be object
    if has_field "agent"; then
        if [[ "$(echo "$config" | jq -r '.agent | type' 2>/dev/null)" != "object" ]]; then
            echo "FAIL: agent must be an object" >&2
            ((errors++))
        fi
    fi

    # Optional: stages must be array with ids
    if has_field "stages"; then
        if [[ "$(echo "$config" | jq -r '.stages | type' 2>/dev/null)" != "array" ]]; then
            echo "FAIL: stages must be a list" >&2
            ((errors++))
        else
            local num_stages
            num_stages=$(echo "$config" | jq '.stages | length' 2>/dev/null)
            for ((i = 0; i < num_stages; i++)); do
                local stage_id
                stage_id=$(echo "$config" | jq -r ".stages[$i].id // \"\"" 2>/dev/null)
                if [[ -z "$stage_id" ]]; then
                    echo "FAIL: Stage $i missing required 'id' field" >&2
                    ((errors++))
                fi
            done
        fi
    fi

    # Optional: stop/notify must be objects
    for field in stop notify; do
        if has_field "$field"; then
            if [[ "$(echo "$config" | jq -r ".$field | type" 2>/dev/null)" != "object" ]]; then
                echo "FAIL: $field must be an object" >&2
                ((errors++))
            fi
        fi
    done

    [[ $errors -eq 0 ]]
}

# ============================================================================
# Commands
# ============================================================================

# autolab init: Initialize a new project
cmd_init() {
    local project_dir="${1:-.}"

    # Create project directory if needed
    if [[ ! -d "$project_dir" ]]; then
        mkdir -p "$project_dir"
    fi

    cd "$project_dir"

    # Check if autolab.yaml already exists (don't overwrite)
    if [[ -f autolab.yaml ]]; then
        info "autolab.yaml already exists, skipping"
    else
        # Create autolab.yaml template
        cat > autolab.yaml << 'YAML'
# Autolab Configuration
project: my-research
description: "A research project"

# What the agent modifies
artifacts:
  - artifact.py

# How to evaluate (must output JSON to stdout)
evaluate: "python3 evaluate.py --json"

# Primary metric to optimize
metric:
  name: f1
  direction: maximize  # or minimize

# Agent configuration
agent:
  command: claude
  flags: "--dangerously-skip-permissions --max-turns 30"

# Roadmap
stages:
  - id: baseline
    goal: "Establish baseline"
    metric: f1
    threshold: 0.60

# Stop conditions
stop:
  max_rounds: 50
  plateau: 5
  time_limit: "1h"

# Notifications
notify:
  slack_channel: null
  on: []
YAML
        info "Created autolab.yaml"
    fi

    # Create program.md template
    if [[ -f program.md ]]; then
        info "program.md already exists, skipping"
    else
        cat > program.md << 'MD'
# Research Instructions

## Objective
Describe the research goal and what success looks like.

## Current State
The agent will see the current artifact and recent experiment history.

## Task
Make one focused improvement to the artifact(s).

## Evaluation
The evaluation script will automatically measure performance.

## Tips
- One change per round
- Document your reasoning
- Each round is independent
MD
        info "Created program.md"
    fi

    # Create evaluate.sh template
    if [[ -f evaluate.sh ]]; then
        info "evaluate.sh already exists, skipping"
    else
        cat > evaluate.sh << 'EVAL'
#!/usr/bin/env bash
set -euo pipefail

# Evaluation script
# Must output valid JSON to stdout
# Exit 0 on success, non-zero on failure

# Example: run some test and compute metrics
# PRECISION=$(python3 -c "print(0.91)")
# RECALL=$(python3 -c "print(0.84)")
# F1=$(python3 -c "print(0.87)")

# For now, output dummy metrics for testing
cat << 'JSON'
{
  "f1": 0.75,
  "precision": 0.80,
  "recall": 0.71
}
JSON
EVAL
        chmod +x evaluate.sh
        info "Created evaluate.sh (executable)"
    fi

    # Create directory structure
    local dirs=(
        "artifacts"
        "data"
        "checkpoints/best"
        "checkpoints/history"
        "results/rounds"
    )

    for dir in "${dirs[@]}"; do
        if [[ ! -d "$dir" ]]; then
            mkdir -p "$dir"
            info "Created directory: $dir"
        fi
    done

    # Create .gitignore if it doesn't exist
    if [[ -f .gitignore ]]; then
        info ".gitignore already exists, skipping"
    else
        cat > .gitignore << 'GITIGNORE'
# Autolab directories
results/
checkpoints/
*.log
__pycache__/
*.pyc
.env
GITIGNORE
        info "Created .gitignore"
    fi

    # Initialize git repo if needed
    if [[ ! -d .git ]]; then
        git init > /dev/null
        git config user.email "autolab@local" 2>/dev/null || true
        git config user.name "Autolab" 2>/dev/null || true
        info "Initialized git repository"
    fi

    # Add initial commit if there are no commits yet
    if ! git rev-parse HEAD &>/dev/null; then
        # Stage all files
        git add autolab.yaml program.md evaluate.sh .gitignore
        git commit -m "Initial autolab project setup" > /dev/null || true
        info "Created initial git commit"
    fi

    echo "Autolab project initialized in $(pwd)"
}

# autolab validate: Validate project config
cmd_validate() {
    local config_file="${1:-.}/autolab.yaml"

    if validate_config "$config_file"; then
        echo "✓ autolab.yaml is valid" >&2
        return 0
    else
        return 1
    fi
}

# ============================================================================
# Eval Command: Run evaluate script and parse metrics
# ============================================================================

# Parse metric from evaluate JSON output
# Usage: parse_metric_from_json <json_string> <metric_name>
parse_metric_from_json() {
    local json_str="$1"
    local metric_name="$2"

    # Extract the metric value from JSON
    echo "$json_str" | jq -r ".\"$metric_name\" // empty" 2>/dev/null
}

# Compare two metric values based on direction
# Usage: compare_metrics <current> <best> <direction>
# Returns: 0 if improved, 1 if regressed or same
compare_metrics() {
    local current="$1"
    local best="$2"
    local direction="$3"

    # Handle non-numeric values
    if ! { echo "$current" | grep -E '^-?[0-9]+(\.[0-9]+)?$' > /dev/null && \
           echo "$best" | grep -E '^-?[0-9]+(\.[0-9]+)?$' > /dev/null; }; then
        die "Invalid numeric metric values: current=$current best=$best"
    fi

    if [[ "$direction" == "maximize" ]]; then
        # Improved if current > best
        (( $(echo "$current > $best" | bc -l) )) && return 0 || return 1
    else
        # Minimized if current < best
        (( $(echo "$current < $best" | bc -l) )) && return 0 || return 1
    fi
}

# autolab eval: Run evaluation script and parse results
cmd_eval() {
    local config_dir="${1:-.}"
    local config_file="$config_dir/autolab.yaml"

    # Validate config exists and is valid
    if [[ ! -f "$config_file" ]]; then
        die "autolab.yaml not found at $config_file"
    fi

    if ! validate_config "$config_file" > /dev/null 2>&1; then
        die "Invalid autolab.yaml: config validation failed"
    fi

    # Parse config
    local config
    if ! config=$(parse_config_to_json "$config_file"); then
        die "Failed to parse autolab.yaml"
    fi

    # Extract evaluate command
    local eval_cmd
    eval_cmd=$(echo "$config" | jq -r '.evaluate' 2>/dev/null)
    if [[ -z "$eval_cmd" || "$eval_cmd" == "null" ]]; then
        die "No evaluate command configured"
    fi

    # Extract metric info
    local metric_name metric_direction
    metric_name=$(echo "$config" | jq -r '.metric.name' 2>/dev/null)
    metric_direction=$(echo "$config" | jq -r '.metric.direction // "maximize"' 2>/dev/null)

    if [[ -z "$metric_name" || "$metric_name" == "null" ]]; then
        die "No metric name configured"
    fi

    # Change to config directory to run evaluate command
    cd "$config_dir"

    # Run evaluate command
    local eval_output
    if ! eval_output=$(eval "$eval_cmd" 2>&1); then
        die "Evaluate command failed: $eval_cmd"
    fi

    # Validate JSON
    if ! echo "$eval_output" | jq empty 2>/dev/null; then
        die "Evaluate script did not return valid JSON: $eval_output"
    fi

    # Parse metric from output
    local metric_value
    metric_value=$(parse_metric_from_json "$eval_output" "$metric_name")

    if [[ -z "$metric_value" ]]; then
        die "Metric '$metric_name' not found in evaluate output"
    fi

    # Output result as JSON
    cat << EOF
{
  "metric": "$metric_name",
  "value": $metric_value,
  "direction": "$metric_direction"
}
EOF
}

# Show help
cmd_help() {
    cat << 'HELP'
autolab — Automated Research Harness

USAGE:
  autolab <command> [args]

COMMANDS:
  init [DIR]          Initialize a new project structure
  validate [DIR]      Validate autolab.yaml
  eval [DIR]          Run evaluate script and parse metrics
  help                Show this help message
  version             Show version

For more information, see DESIGN.md and CLAUDE.md
HELP
}

# Show version
cmd_version() {
    echo "autolab version $AUTOLAB_VERSION"
}

# ============================================================================
# Main
# ============================================================================

main() {
    check_deps

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        init)      cmd_init "$@" ;;
        validate)  cmd_validate "$@" ;;
        eval)      cmd_eval "$@" ;;
        help)      cmd_help ;;
        version)   cmd_version ;;
        *)         die "Unknown command: $cmd (use 'autolab help')" ;;
    esac
}

main "$@"
